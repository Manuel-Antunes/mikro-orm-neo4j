{
  "name": "mikro-orm-neo4j",
  "version": "0.2.0",
  "description": "Neo4j driver for MikroORM (OGM-style graph support)",
  "author": "Manuel Antunes",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@neo4j/cypher-builder": "^2.12.0",
    "camelcase": "^9.0.0",
    "debug": "^4.4.3",
    "neo4j-driver": "^5.26.0",
    "pluralize": "^8.0.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@mikro-orm/core": "^7.0.2",
    "@mikro-orm/decorators": "^7.0.2",
    "@mikro-orm/reflection": "^7.0.2",
    "@swc/core": "^1.15.26",
    "@types/debug": "^4.1.13",
    "@types/node": "^22.13.5",
    "@types/pluralize": "^0.0.33",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.1",
    "prettier": "^3.5.2",
    "reflect-metadata": "^0.2.2",
    "testcontainers": "^11.14.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@mikro-orm/core": "^7.0.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Manuel-Antunes/mikro-orm-neo4j.git"
  },
  "keywords": [
    "mikro-orm",
    "neo4j",
    "ogm",
    "orm",
    "cypher",
    "typescript"
  ]
}